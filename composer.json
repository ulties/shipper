{
    "name": "ulties/shipper",
    "description": "A shipper application built with Laravel Zero with strict type checking",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.0",
        "larastan/larastan": "^3.9",
        "laravel-zero/framework": "^12.1",
        "laravel/forge-sdk": "^3.25",
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.0",
        "ploi/ploi-php-sdk": "^1.9",
        "symfony/clock": "^7.3",
        "symfony/console": "^7.3",
        "symfony/string": "^7.3",
        "symfony/translation": "^7.3",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "php vendor/bin/pest",
        "analyse": "php phpstan.phar analyse --memory-limit=1G",
        "format": "php pint.phar",
        "format:check": "php pint.phar --test",
        "build": [
            "[ -f box.phar ] || (curl -LSso box.phar https://github.com/box-project/box/releases/latest/download/box.phar && chmod +x box.phar) || (echo 'Failed to download Box' && exit 1)",
            "php box.phar compile"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "platform": {
        }
    }
}
