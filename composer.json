{
    "name": "ulties/deployer",
    "description": "A deployer application built with Laravel Zero with strict type checking",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel-zero/framework": "^12.0",
        "ploi/ploi-php-sdk": "^1.9",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "*",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "@php -r \"file_exists('vendor/bin/pest') ? exit(0) : exit(1);\" || echo 'Dev dependencies required. Run: composer install'",
            "@php -r \"if (file_exists('vendor/bin/pest')) { passthru('vendor/bin/pest', $exitCode); exit($exitCode); }\""
        ],
        "analyse": "php phpstan.phar analyse --memory-limit=1G",
        "format": "php pint.phar",
        "format:check": "php pint.phar --test"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
